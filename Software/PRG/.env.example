# ============================================================================
# Benning / DGUV3 Device Manager - Environment Variables für Podman
# ============================================================================
# Nutzung auf neuem PC:
#   cp env.template .env
#   nano .env
#   podman-compose up -d --build
# ============================================================================

# Database Configuration innerhalb des Podman-Netzwerks
DB_HOST=mysql
DB_PORT=3306
DB_USER=dguv3
DB_PASSWORD=change_me_dguv3
DB_NAME=dguv3_db
DB_ROOT_PASSWORD=change_me_root

# Port, unter dem MySQL auf dem Host erreichbar ist
# Container-intern bleibt MySQL immer auf 3306.
DB_HOST_PORT=3307

# Standardkunde / Präfix für neue Geräte-IDs, z. B. TSS-00001
DEFAULT_CUSTOMER=TSS

# Flask Configuration
FLASK_APP=src.main
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_PORT=5000

# Application Configuration
APP_WORKERS=4
APP_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
SECRET_KEY=change-me-to-a-long-random-secret
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Python Runtime
PYTHONOPTIMIZE=2
PYTHONUNBUFFERED=1

# Optional: Nginx (für Production)
NGINX_PORT=80
NGINX_SSL_PORT=443
